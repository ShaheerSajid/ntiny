diff --git a/arch/riscv/kernel/cpufeature.c b/arch/riscv/kernel/cpufeature.c
index 1cfbba65d..468d6b170 100644
--- a/arch/riscv/kernel/cpufeature.c
+++ b/arch/riscv/kernel/cpufeature.c
@@ -651,7 +651,13 @@ static int check_unaligned_access_boot_cpu(void)
 	return 0;
 }
 
-arch_initcall(check_unaligned_access_boot_cpu);
+/* ntiny: disabled — the busy-loop-on-jiffies inside check_unaligned_access
+ * spins waiting for the timer IRQ to bump jiffies, but at this initcall
+ * stage our SBI timer chain hasn't yet started servicing the kernel side
+ * predictably enough; the loop never exits and Linux hangs early in boot.
+ * Skipping this only loses the per-cpu unaligned-access-speed hwcap, which
+ * we don't use anyway. */
+//arch_initcall(check_unaligned_access_boot_cpu);
 
 #ifdef CONFIG_RISCV_ALTERNATIVE
 /*
diff --git a/arch/riscv/kernel/head.S b/arch/riscv/kernel/head.S
index 3710ea5d1..d5ef2063d 100644
--- a/arch/riscv/kernel/head.S
+++ b/arch/riscv/kernel/head.S
@@ -298,6 +298,12 @@ clear_bss_done:
 	la sp, init_thread_union + THREAD_SIZE
 	XIP_FIXUP_OFFSET sp
 	addi sp, sp, -PT_SIZE_ON_STACK
+	/* ntiny: initialize kernel_sp in thread_info so S-mode traps
+	 * during early boot (before any context switch) use the correct
+	 * kernel stack pointer. Without this, the trap handler's
+	 * _save_context loads a stale kernel_sp, and the trap frame
+	 * overlaps with the active call stack, corrupting saved registers. */
+	REG_S sp, TASK_TI_KERNEL_SP(tp)
 #ifdef CONFIG_BUILTIN_DTB
 	la a0, __dtb_start
 	XIP_FIXUP_OFFSET a0
