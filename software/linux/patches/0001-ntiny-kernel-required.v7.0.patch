diff --git a/arch/riscv/boot/dts/Makefile b/arch/riscv/boot/dts/Makefile
index 69d8751fb..88a3f3b08 100644
--- a/arch/riscv/boot/dts/Makefile
+++ b/arch/riscv/boot/dts/Makefile
@@ -5,6 +5,7 @@ subdir-y += anlogic
 subdir-y += canaan
 subdir-y += eswin
 subdir-y += microchip
+subdir-y += ntiny
 subdir-y += renesas
 subdir-y += sifive
 subdir-y += sophgo
diff --git a/arch/riscv/kernel/head.S b/arch/riscv/kernel/head.S
index 9c99c5ad6..b6e74f595 100644
--- a/arch/riscv/kernel/head.S
+++ b/arch/riscv/kernel/head.S
@@ -322,6 +322,12 @@ SYM_CODE_START(_start_kernel)
 	la sp, init_thread_union + THREAD_SIZE
 	XIP_FIXUP_OFFSET sp
 	addi sp, sp, -PT_SIZE_ON_STACK
+	/* ntiny: initialize kernel_sp in thread_info so S-mode traps
+	 * during early boot (before any context switch) use the correct
+	 * kernel stack pointer. Without this, the trap handler's
+	 * _save_context loads a stale kernel_sp, and the trap frame
+	 * overlaps with the active call stack, corrupting saved registers. */
+	REG_S sp, TASK_TI_KERNEL_SP(tp)
 	scs_load_init_stack
 #ifdef CONFIG_BUILTIN_DTB
 	la a0, __dtb_start
