CONFIG_BLK_DEV_INITRD=y
# Pin the version string deterministically (avoids "-dirty" from
# scripts/setlocalversion when the kernel tree has uncommitted ntiny
# patches): 6.6.0-ntiny instead of 6.6.0-dirty.
CONFIG_LOCALVERSION="-ntiny"
# CONFIG_LOCALVERSION_AUTO is not set
CONFIG_INITRAMFS_SOURCE="@NTINY_LINUX@/initramfs.cpio"
CONFIG_INITRAMFS_COMPRESSION_NONE=y
CONFIG_EXPERT=y
CONFIG_SOC_VIRT=y
CONFIG_NONPORTABLE=y
CONFIG_ARCH_RV32I=y
CONFIG_RISCV_ISA_ZBB=y
# 6.12: disable boot-time unaligned-access probing (busy-loops on jiffies
# before timers settle). Tell kernel HW handles unaligned slow-but-OK.
CONFIG_RISCV_SLOW_UNALIGNED_ACCESS=y
# CONFIG_IRQ_STACKS is not set
CONFIG_RISCV_SBI_V01=y
CONFIG_CMDLINE="earlycon=sbi console=hvc0"
CONFIG_CMDLINE_FORCE=y
# CONFIG_STACKPROTECTOR is not set
# CONFIG_BLOCK is not set
# Headless RV32 SoC: console is HVC over SBI, no VT/keyboard/mouse.
# CONFIG_VT must go first — it `select INPUT`s, which otherwise pulls
# in CONFIG_MOUSE_PS2 + the full PS/2 driver family. Their __param
# entries trip a kernfs refcount underflow in param_sysfs_builtin_init
# on fresh (non-incremental) builds and panic init before /init runs.
# CONFIG_VT is not set
# CONFIG_INPUT is not set
# CONFIG_HID_SUPPORT is not set
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_SERIAL_EARLYCON_RISCV_SBI=y
CONFIG_HVC_RISCV_SBI=y
CONFIG_TMPFS=y
CONFIG_FTRACE=y
CONFIG_FTRACE_SYSCALLS=y
# Phase 1: driver Kconfigs for the upstream IPs the ntiny peripheral
# nodes target (see software/linux/ntiny.dts +
# docs/peripheral_standardization_plan.md). Drivers will probe, most
# will fail to bind until Phase 2 RTL refactors land — that's expected.
CONFIG_SERIAL_SIFIVE=y
CONFIG_SERIAL_SIFIVE_CONSOLE=y
CONFIG_GPIOLIB=y
CONFIG_GPIO_SYSFS=y
CONFIG_GPIO_SIFIVE=y
CONFIG_SPI=y
CONFIG_SPI_MASTER=y
CONFIG_SPI_SIFIVE=y
CONFIG_SPI_SPIDEV=y
CONFIG_I2C=y
CONFIG_I2C_CHARDEV=y
CONFIG_I2C_OCORES=y
CONFIG_PWM=y
CONFIG_PWM_SIFIVE=y
CONFIG_UIO=y
CONFIG_UIO_PDRV_GENIRQ=y
