# ntiny minimal initramfs spec for gen_init_cpio.
#
# - /dev/console char device (so the kernel can open it as fd 0/1/2 for init)
# - /init binary (built from init.c in this directory; raw syscalls, no libc)
# - empty /proc and /sys directories so the init can mount them later if needed

dir  /dev      0755 0 0
nod  /dev/console 0600 0 0 c 5 1
dir  /proc     0755 0 0
dir  /sys      0755 0 0
dir  /root     0700 0 0
file /init     /home/shaheer/Documents/github/ntiny/software/linux/initramfs_src/init 0755 0 0
