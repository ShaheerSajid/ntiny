/dts-v1/;

/ {
    #address-cells = <1>;
    #size-cells = <1>;
    compatible = "ntiny,ntiny-soc";
    model = "ntiny RISC-V SoC";

    chosen {
        bootargs = "earlycon=sbi console=hvc0";
        stdout-path = "/soc/serial@10000000";
    };

    cpus {
        #address-cells = <1>;
        #size-cells = <0>;
        timebase-frequency = <50000000>;

        cpu@0 {
            device_type = "cpu";
            reg = <0>;
            compatible = "riscv";
            riscv,isa = "rv32imacsu";
            mmu-type = "riscv,sv32";

            interrupt-controller {
                #interrupt-cells = <1>;
                interrupt-controller;
                compatible = "riscv,cpu-intc";
                phandle = <1>;
            };
        };
    };

    memory@80000000 {
        device_type = "memory";
        reg = <0x80000000 0x08000000>;  /* 128 MB */
    };

    soc {
        #address-cells = <1>;
        #size-cells = <1>;
        compatible = "simple-bus";
        ranges;

        clint@2000000 {
            compatible = "riscv,clint0";
            reg = <0x02000000 0x10000>;
            interrupts-extended = <&{/cpus/cpu@0/interrupt-controller} 3>,  /* MSIP */
                                  <&{/cpus/cpu@0/interrupt-controller} 7>;  /* MTIP */
        };

        plic@c000000 {
            compatible = "riscv,plic0";
            reg = <0x0c000000 0x02000000>;
            #interrupt-cells = <1>;
            interrupt-controller;
            interrupts-extended = <&{/cpus/cpu@0/interrupt-controller} 11>; /* MEIP */
            riscv,ndev = <6>;
            phandle = <2>;
        };

        serial@10000000 {
            compatible = "ntiny,uart";
            reg = <0x10000000 0x1000>;
            /* UART registers: RX=0x0, TX=0x4, STATUS=0x8, CONTROL=0xC, BAUDRATE=0x10 */
        };
    };
};
