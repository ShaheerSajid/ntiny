{
    "_comment": "ntiny unified memory map — single source of truth. Run: python3 scripts/gen_mem_map.py",

    "profiles": {
        "default": {
            "_comment": "Taped-out SoC defaults (TSMC 65nm)",
            "RAM_BASE":       "0x80000000",
            "RAM_SIZE_BYTES": "0x00008000",
            "BOOT_BASE":      "0x00001000",
            "BOOT_SIZE_BYTES":"0x00001000"
        },
        "riscof": {
            "_comment": "RISCOF compliance testing — large RAM for vm_sv32 page tables",
            "RAM_BASE":       "0x80000000",
            "RAM_SIZE_BYTES": "0x01000000",
            "BOOT_BASE":      "0x00001000",
            "BOOT_SIZE_BYTES":"0x00001000"
        },
        "linux": {
            "_comment": "Linux boot — 128MB RAM for OpenSBI + kernel + rootfs",
            "RAM_BASE":       "0x80000000",
            "RAM_SIZE_BYTES": "0x08000000",
            "BOOT_BASE":      "0x00001000",
            "BOOT_SIZE_BYTES":"0x00001000"
        }
    },

    "peripherals": {
        "UART":     { "base": "0x10000000", "end": "0x10000FFF" },
        "SPI":      { "base": "0x10010000", "end": "0x10010FFF" },
        "I2C":      { "base": "0x10020000", "end": "0x10020FFF" },
        "GPIO":     { "base": "0x10030000", "end": "0x10030FFF" },
        "PWM":      { "base": "0x10040000", "end": "0x10040FFF" },
        "TIMER":    { "base": "0x10050000", "end": "0x10050FFF" },
        "CRC":      { "base": "0x10060000", "end": "0x10060FFF" },
        "CLINT":    { "base": "0x02000000", "end": "0x0200FFFF" },
        "PLIC":     { "base": "0x0C000000", "end": "0x0DFFFFFF" }
    },

    "special": {
        "SOFT_INT_ADDR": "0x10070000",
        "TOHOST_ADDR":   "0x0F000000"
    }
}
