# ntiny build/run configuration — single source of truth for tool paths.
#
# Syntax: VAR=value (no spaces, no quotes). Valid in BOTH GNU Make
# (`include .env`) and POSIX shell (`. .env`). Override per-invocation
# by setting the variable in the environment before make/the script.

# Bare-metal RISC-V toolchain (rv32/rv64 multilib elf).
TOOLCHAIN_ELF=/opt/riscv-elf/bin

# Linux RISC-V toolchain (used by software/linux/Makefile).
TOOLCHAIN_LINUX=/opt/riscv-linux-gnu/bin

# Spike ISS (used by RISCOF as the reference model).
SPIKE_BIN=/opt/spike/bin

# RISCOF venv activate script (any working python venv with riscof installed).
RISCOF_VENV=/home/shaheer/Software/riscof_env/bin/activate
